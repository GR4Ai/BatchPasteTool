#include <windows.h>
#include "src/resource.h"

// Application icon (Will be loaded from resources/ at runtime via GDI+)
// IDI_APP_ICON  ICON  "resources/app_icon.png"

// DPI awareness and visual styles manifest
IDR_MANIFEST 24 1 "BatchPasteTool.manifest"

// Version info
VS_VERSION_INFO VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEFLAGSMASK   0x3fL
FILEFLAGS       0x0L
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      ""
            VALUE "FileDescription",  "BatchPasteTool - Batch text paste utility"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "BatchPasteTool"
            VALUE "LegalCopyright",   ""
            VALUE "OriginalFilename", "BatchPasteTool.exe"
            VALUE "ProductName",      "BatchPasteTool"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
