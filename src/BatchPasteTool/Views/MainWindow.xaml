<Window x:Class="BatchPasteTool.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BatchPasteTool.Views"
        xmlns:vm="clr-namespace:BatchPasteTool.ViewModels"
        xmlns:conv="clr-namespace:BatchPasteTool.Views.Converters"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#B4B4B4"
        ResizeMode="CanResize"
        MinWidth="420"
        MinHeight="220"
        Width="620"
        Height="500"
        SizeToContent="Manual"
        WindowStartupLocation="Manual"
        Title="BatchPasteTool"
        Icon="pack://application:,,,/BatchPasteTool;component/Resources/app_icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InverseBool"/>

        <!-- ============================================================ -->
        <!--  WINDOW BUTTON STYLE (Min/Max/Close)                        -->
        <!-- ============================================================ -->
        <Style x:Key="WinBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1A1A1A"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E0E0E0"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Close button (red hover) -->
        <Style x:Key="CloseBtnStyle" TargetType="Button" BasedOn="{StaticResource WinBtnStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E81123"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!--  ICON BUTTON STYLE (Pin, Transparency, Add, Del, Undo)      -->
        <!-- ============================================================ -->
        <Style x:Key="IconBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Width="24" Height="24">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#644285F4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!--  SEND BUTTON STYLE                                           -->
        <!-- ============================================================ -->
        <Style x:Key="SendBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#326EDC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="1"
                                Width="52" Height="26">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1450B4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!--  CLEAR (X) BUTTON STYLE                                      -->
        <!-- ============================================================ -->
        <Style x:Key="ClearBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#828282"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Width="24" Height="26">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#DC3C32"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!--  BOTTOM TEXT BUTTON STYLE (Clear All, Clear Texts)          -->
        <!-- ============================================================ -->
        <Style x:Key="BottomTextBtnStyle" TargetType="Button">
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#326EDC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                Width="56" Height="30">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#1450B4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ============================================================ -->
        <!--  ITEM DATATEMPLATE                                           -->
        <!-- ============================================================ -->
        <DataTemplate x:Key="ItemTemplate" DataType="{x:Type vm:PasteItemViewModel}">
            <Grid Height="40" Margin="4,0,4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <!-- Item background -->
                <Border Grid.ColumnSpan="3" Background="#F0F0F0" CornerRadius="1"/>

                <!-- TextBox -->
                <TextBox Grid.Column="0"
                         Height="26"
                         VerticalAlignment="Center"
                         Margin="8,0,4,0"
                         Background="White"
                         FontFamily="Segoe UI"
                         FontSize="18"
                         Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                         BorderBrush="#DDDDDD"
                         BorderThickness="1"
                         GotFocus="ItemTextBox_GotFocus"
                         LostFocus="ItemTextBox_LostFocus"/>

                <!-- Clear (X) button -->
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Style="{StaticResource ClearBtnStyle}"
                        Content="✕"
                        Command="{Binding DataContext.ClearItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"/>

                <!-- Send button -->
                <Button Grid.Column="2"
                        VerticalAlignment="Center"
                        Style="{StaticResource SendBtnStyle}"
                        Content="Send"
                        Command="{Binding DataContext.SendItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"/>

                <!-- Separator line -->
                <Line Grid.ColumnSpan="3"
                      VerticalAlignment="Bottom"
                      Stroke="#BEBEBE" StrokeThickness="1"
                      Margin="4,0,4,-1"/>
            </Grid>
        </DataTemplate>

        <!-- ============================================================ -->
        <!--  SLIDER TEMPLATE  (proper WPF Track/Thumb parts)             -->
        <!-- ============================================================ -->
        <ControlTemplate x:Key="CustomSliderTemplate" TargetType="Slider">
            <Grid Height="18" Width="140">
                <Track x:Name="PART_Track" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                    <Track.DecreaseRepeatButton>
                        <RepeatButton Command="Slider.DecreaseLarge">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Height="6" CornerRadius="3,0,0,3" Background="#4285F4"
                                            Margin="6,0,0,0"/>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Track.DecreaseRepeatButton>
                    <Track.IncreaseRepeatButton>
                        <RepeatButton Command="Slider.IncreaseLarge">
                            <RepeatButton.Template>
                                <ControlTemplate TargetType="RepeatButton">
                                    <Border Height="6" CornerRadius="0,3,3,0" Background="#B4B4B4"
                                            Margin="0,0,6,0"/>
                                </ControlTemplate>
                            </RepeatButton.Template>
                        </RepeatButton>
                    </Track.IncreaseRepeatButton>
                    <Track.Thumb>
                        <Thumb x:Name="PART_Thumb" Width="12" Height="12"
                               Cursor="Hand">
                            <Thumb.Template>
                                <ControlTemplate TargetType="Thumb">
                                    <Ellipse Width="12" Height="12"
                                             Fill="#4285F4"
                                             Stroke="#2864C8"
                                             StrokeThickness="1.5"/>
                                </ControlTemplate>
                            </Thumb.Template>
                        </Thumb>
                    </Track.Thumb>
                </Track>
            </Grid>
        </ControlTemplate>
    </Window.Resources>

    <!-- ================================================================ -->
    <!--  MAIN LAYOUT                                                     -->
    <!-- ================================================================ -->
    <Grid Margin="1" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>  <!-- Title bar -->
            <RowDefinition Height="*"/>   <!-- Content area -->
            <RowDefinition Height="42"/>  <!-- Bottom bar -->
        </Grid.RowDefinitions>

                <!-- ==================================================== -->
                <!--  ROW 0: TITLE BAR                                    -->
                <!-- ==================================================== -->
                <Grid Grid.Row="0" Background="White"
                      MouseLeftButtonDown="TitleBar_MouseDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: App name + Pin button -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0">
                        <TextBlock Text="BatchPasteTool"
                                   FontFamily="Segoe UI"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#1A1A1A"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <Button Width="24" Height="24"
                                Style="{StaticResource IconBtnStyle}"
                                Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Image Width="24" Height="24">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Source" Value="pack://application:,,,/BatchPasteTool;component/Resources/pin.png"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsPinned, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Source" Value="pack://application:,,,/BatchPasteTool;component/Resources/pin_filled.png"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>
                        </Button>
                    </StackPanel>

                    <!-- MIDDLE: Transparency icon -->
                    <Button Grid.Column="1" Width="24" Height="24"
                            HorizontalAlignment="Center"
                            Style="{StaticResource IconBtnStyle}"
                            Command="{Binding DataContext.ToggleTransparencyCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Image Source="pack://application:,,,/BatchPasteTool;component/Resources/transparency.png"
                               Width="24" Height="24"/>
                    </Button>

                    <!-- RIGHT: Transparency slider + Window buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <!-- Transparency slider -->
                        <Slider x:Name="TranspSlider"
                                Width="140" Height="18"
                                Minimum="0" Maximum="1"
                                Value="{Binding SliderRatio, Mode=TwoWay}"
                                VerticalAlignment="Center"
                                Template="{StaticResource CustomSliderTemplate}"
                                Margin="0,0,10,0"/>

                        <!-- Min button -->
                        <Button Style="{StaticResource WinBtnStyle}"
                                Command="{Binding DataContext.MinimizeCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Path Data="M 0,6 L 10,6"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Width="10" Height="12"/>
                        </Button>

                        <!-- Max button -->
                        <Button Style="{StaticResource WinBtnStyle}"
                                Command="{Binding DataContext.MaximizeRestoreCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Path Data="M 0.5,1.5 L 9.5,1.5 L 9.5,10.5 L 0.5,10.5 Z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1" StrokeLineJoin="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Width="10" Height="12"/>
                        </Button>

                        <!-- Close button -->
                        <Button Style="{StaticResource CloseBtnStyle}"
                                Command="{Binding DataContext.CloseCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                            <Path Data="M 1,1 L 9,9 M 9,1 L 1,9"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.2" StrokeEndLineCap="Round" StrokeStartLineCap="Round"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Width="10" Height="12"/>
                        </Button>
                    </StackPanel>

                    <!-- Title bar bottom separator -->
                    <Line Grid.ColumnSpan="3"
                          VerticalAlignment="Bottom"
                          Stroke="#C8C8C8" StrokeThickness="1"/>
                </Grid>

                <!-- ==================================================== -->
                <!--  ROW 1: CONTENT AREA                                 -->
                <!-- ==================================================== -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>

                    <!-- Scrollable items list -->
                    <ScrollViewer x:Name="ContentScroller"
                                  Grid.Column="0"
                                  CanContentScroll="True"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Hidden"
                                  Background="White"
                                  ScrollChanged="ContentScroller_ScrollChanged">
                        <ItemsControl ItemsSource="{Binding Items}"
                                      ItemTemplate="{StaticResource ItemTemplate}"
                                      VirtualizingStackPanel.IsVirtualizing="True"
                                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Vertical scrollbar -->
                    <ScrollBar x:Name="VertScrollbar"
                               Grid.Column="1"
                               Orientation="Vertical"
                               Width="16"
                               SmallChange="38"
                               LargeChange="200"
                               Scroll="VertScrollbar_Scroll"/>
                </Grid>

                <!-- ==================================================== -->
                <!--  ROW 2: BOTTOM BAR                                   -->
                <!-- ==================================================== -->
                <Grid Grid.Row="2" Background="White"
                      x:Name="BottomBar"
                      SnapsToDevicePixels="True"
                      TextOptions.TextFormattingMode="Display">
                    <Grid.CacheMode>
                        <BitmapCache EnableClearType="False"
                                     SnapsToDevicePixels="True"
                                     RenderAtScale="1"/>
                    </Grid.CacheMode>
                    <!-- Top separator -->
                    <Line VerticalAlignment="Top"
                          Stroke="#B4B4B4" StrokeThickness="1"/>

                    <!-- Left icon buttons -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="10,0,0,0">

                        <!-- Add button -->
                        <Button Width="24" Height="24"
                                Style="{StaticResource IconBtnStyle}"
                                Command="{Binding DataContext.AddItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Margin="0,0,8,0">
                            <Image Source="pack://application:,,,/BatchPasteTool;component/Resources/add.png"
                                   Width="24" Height="24"/>
                        </Button>

                        <!-- Delete button -->
                        <Button Width="24" Height="24"
                                Style="{StaticResource IconBtnStyle}"
                                Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Margin="0,0,8,0"
                                IsEnabled="{Binding CanDelete}">
                            <Image Source="pack://application:,,,/BatchPasteTool;component/Resources/delete.png"
                                   Width="24" Height="24"
                                   Opacity="{Binding CanDelete, Converter={StaticResource InverseBool}, ConverterParameter=0.25}"/>
                        </Button>

                        <!-- Undo button -->
                        <Button Width="24" Height="24"
                                Style="{StaticResource IconBtnStyle}"
                                Command="{Binding DataContext.UndoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                IsEnabled="{Binding CanUndo}">
                            <Image Source="pack://application:,,,/BatchPasteTool;component/Resources/undo.png"
                                   Width="24" Height="24"/>
                        </Button>
                    </StackPanel>

                    <!-- Right text buttons -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Right"
                                Margin="0,0,10,0">

                        <!-- Clear All button -->
                        <Button Content="Clear All"
                                Style="{StaticResource BottomTextBtnStyle}"
                                Width="84"
                                Command="{Binding DataContext.ClearAllItemsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                Margin="0,0,8,0"/>

                        <!-- Clear Texts button -->
                        <Button Content="Clear"
                                Style="{StaticResource BottomTextBtnStyle}"
                                Command="{Binding DataContext.ClearAllTextsCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </Grid>
    </Grid>
</Window>
